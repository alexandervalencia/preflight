<section class="pf-page pf-page--wide" data-controller="tree-toggle">
  <%= render "pull_requests/repository_header", local_repository: @local_repository %>

  <%= render "pull_requests/pull_request_header",
    local_repository: @local_repository,
    pull_request: @pull_request,
    comparison: @comparison,
    active_tab: :commits %>

  <section class="pf-review-toolbar">
    <div class="pf-review-toolbar__left">
      <button type="button"
        class="pf-toolbar-button pf-toolbar-button--icon"
        data-tree-toggle-target="button"
        data-action="tree-toggle#toggle"
        aria-label="<%= @show_file_tree ? "Hide file tree" : "Show file tree" %>">
        <span data-tree-toggle-target="collapseIcon" <%= 'hidden' unless @show_file_tree %>><%= octicon(:sidebar_collapse, size: 16) %></span>
        <span data-tree-toggle-target="expandIcon" <%= 'hidden' if @show_file_tree %>><%= octicon(:sidebar_expand, size: 16) %></span>
      </button>
      <span class="pf-toolbar-pill">Commit <strong><%= @commit.short_sha %></strong></span>
      <details class="pf-diff-settings" data-role="diff-settings">
        <summary class="pf-toolbar-button pf-toolbar-button--icon" aria-label="Diff settings">
          <%= octicon(:gear, size: 16) %>
        </summary>
        <div class="pf-diff-settings__menu">
          <p class="pf-diff-settings__label">Layout</p>
          <%= link_to "Unified",
            repository_pull_commit_path(@local_repository, @pull_request, @commit.sha, diff_layout_query(request.query_parameters, layout: "unified")),
            class: ["pf-diff-settings__option", ("pf-diff-settings__option--active" if @layout == :unified)] %>
          <%= link_to "Split",
            repository_pull_commit_path(@local_repository, @pull_request, @commit.sha, diff_layout_query(request.query_parameters, layout: "split")),
            class: ["pf-diff-settings__option", ("pf-diff-settings__option--active" if @layout == :split)] %>
          <%= link_to(@compact_line_height ? "Compact line height" : "Comfortable line height",
            repository_pull_commit_path(@local_repository, @pull_request, @commit.sha, diff_layout_query(request.query_parameters, compact: (@compact_line_height ? "0" : "1"))),
            class: ["pf-diff-settings__option", ("pf-diff-settings__option--active" if @compact_line_height)]) %>
        </div>
      </details>
    </div>
  </section>

  <% ordered_files = ordered_diff_files(@files) %>

  <div class="pf-review-layout <%= "pf-review-layout--tree-hidden" unless @show_file_tree %>" data-tree-toggle-target="layout">
    <%= render "pull_requests/file_tree",
      files: ordered_files,
      query: @query,
      filter_path: repository_pull_commit_path(@local_repository, @pull_request, @commit.sha),
      layout: @layout,
      compact_line_height: @compact_line_height,
      show_file_tree: @show_file_tree %>

    <section class="pf-diff-column">
      <article class="pf-commit-summary" data-role="commit-summary">
        <div class="pf-commit-summary__title-row">
          <p class="pf-commit-summary__message"><%= format_commit_message(@commit.message) %></p>
          <% if @comparison.commits.length > 1 %>
            <div class="pf-commit-summary__nav-buttons">
              <% if @previous_commit %>
                <%= link_to repository_pull_commit_path(@local_repository, @pull_request, @previous_commit.sha), class: "pf-button pf-button--secondary pf-button--small" do %>
                  <%= octicon(:chevron_down, size: 16, class_name: "pf-chevron-left") %> Prev
                <% end %>
              <% else %>
                <span class="pf-button pf-button--secondary pf-button--small pf-button--disabled">
                  <%= octicon(:chevron_down, size: 16, class_name: "pf-chevron-left") %> Prev
                </span>
              <% end %>
              <% if @next_commit %>
                <%= link_to repository_pull_commit_path(@local_repository, @pull_request, @next_commit.sha), class: "pf-button pf-button--secondary pf-button--small" do %>
                  Next <%= octicon(:chevron_down, size: 16, class_name: "pf-chevron-right") %>
                <% end %>
              <% else %>
                <span class="pf-button pf-button--secondary pf-button--small pf-button--disabled">
                  Next <%= octicon(:chevron_down, size: 16, class_name: "pf-chevron-right") %>
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
        <% if @commit.body.present? %>
          <pre class="pf-commit-summary__body"><%= @commit.body %></pre>
        <% end %>
        <div class="pf-commit-summary__footer">
          <span><%= @commit.author_name %> committed <%= time_ago_in_words(@commit.authored_at) %> ago</span>
          <code>commit <%= @commit.sha %></code>
        </div>
      </article>

      <% ordered_files.each do |file| %>
        <%= render "pull_requests/diff_file",
          local_repository: @local_repository,
          pull_request: @pull_request,
          file: file,
          commit_sha: @commit.sha,
          redirect_path: repository_pull_commit_path(@local_repository, @pull_request, @commit.sha),
          layout: @layout,
          compact_line_height: @compact_line_height,
          show_review_state: false %>
      <% end %>
    </section>
  </div>
</section>
