<section class="page">
  <header class="page-header">
    <p class="eyebrow">Commit review</p>
    <h1><%= @commit.message %></h1>
    <p><%= link_to @local_repository.name, repository_pull_requests_path(@local_repository) %></p>
    <div class="branch-row">
      <span class="branch-pill"><%= @pull_request.base_branch %></span>
      <span class="branch-arrow">&larr;</span>
      <span class="branch-pill"><%= @pull_request.source_branch %></span>
    </div>
  </header>

  <section class="panel commit-review-header">
    <div class="commit-review-header__meta">
      <strong>Commit <%= @current_index + 1 %> of <%= @comparison.commits.length %></strong>
      <span><code><%= @commit.short_sha %></code></span>
    </div>
    <div class="commit-navigation">
      <% if @previous_commit %>
        <%= link_to "Previous", pull_request_commit_path(@pull_request, @previous_commit.sha), class: "button button-secondary button-small" %>
      <% else %>
        <span></span>
      <% end %>

      <%= link_to "Back to pull request", repository_pull_request_path(@local_repository, @pull_request), class: "button button-secondary button-small" %>

      <% if @next_commit %>
        <%= link_to "Next", pull_request_commit_path(@pull_request, @next_commit.sha), class: "button button-secondary button-small" %>
      <% else %>
        <span></span>
      <% end %>
    </div>
  </section>

  <section class="panel commit-strip-panel">
    <div class="panel-header">
      <h2>Commits</h2>
    </div>
    <ol class="commit-strip" data-role="commit-rail">
      <% @comparison.commits.each do |commit| %>
        <li class="<%= "commit-current" if commit.sha == @commit.sha %>">
          <%= link_to pull_request_commit_path(@pull_request, commit.sha), class: "commit-chip" do %>
            <strong><%= commit.message %></strong>
            <span><%= commit.short_sha %></span>
          <% end %>
        </li>
      <% end %>
    </ol>
  </section>

  <section class="panel commit-diff-panel">
    <div class="panel-header">
      <h2>Files changed in this commit</h2>
    </div>
    <div class="changed-files">
      <% @commit.files.each do |file| %>
        <%= render "pull_requests/diff_file",
          pull_request: @pull_request,
          file: file,
          comments_by_key: @comments_by_key,
          commit_sha: @commit.sha,
          redirect_path: pull_request_commit_path(@pull_request, @commit.sha),
          show_review_state: false %>
      <% end %>
    </div>
  </section>
</section>
