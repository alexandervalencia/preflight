<section class="gh-page gh-page--wide">
  <%= render "pull_requests/repository_header", local_repository: @local_repository %>

  <%= render "pull_requests/pull_request_header",
    local_repository: @local_repository,
    pull_request: @pull_request,
    comparison: @comparison,
    active_tab: :commits %>

  <section class="gh-review-toolbar">
    <div class="gh-review-toolbar__left">
      <%= link_to(@show_file_tree ? "Hide file tree" : "Show file tree",
        pull_request_commit_path(
          @pull_request,
          @commit.sha,
          diff_layout_query(request.query_parameters, tree: (@show_file_tree ? "0" : "1"))
        ),
        class: "gh-toolbar-button") %>
      <span class="gh-toolbar-pill">Commit <strong><%= @commit.short_sha %></strong></span>
      <details class="gh-diff-settings" data-role="diff-settings">
        <summary class="gh-toolbar-button gh-toolbar-button--icon" aria-label="Diff settings">
          <span>&#9881;</span>
        </summary>
        <div class="gh-diff-settings__menu">
          <p class="gh-diff-settings__label">Layout</p>
          <%= link_to "Unified",
            pull_request_commit_path(@pull_request, @commit.sha, diff_layout_query(request.query_parameters, layout: "unified")),
            class: ["gh-diff-settings__option", ("gh-diff-settings__option--active" if @layout == :unified)] %>
          <%= link_to "Split",
            pull_request_commit_path(@pull_request, @commit.sha, diff_layout_query(request.query_parameters, layout: "split")),
            class: ["gh-diff-settings__option", ("gh-diff-settings__option--active" if @layout == :split)] %>
          <%= link_to(@compact_line_height ? "Compact line height" : "Comfortable line height",
            pull_request_commit_path(@pull_request, @commit.sha, diff_layout_query(request.query_parameters, compact: (@compact_line_height ? "0" : "1"))),
            class: ["gh-diff-settings__option", ("gh-diff-settings__option--active" if @compact_line_height)]) %>
        </div>
      </details>
    </div>
  </section>

  <div class="gh-review-layout <%= "gh-review-layout--tree-hidden" unless @show_file_tree %>">
    <% if @show_file_tree %>
      <%= render "pull_requests/file_tree",
        files: @commit.files,
        query: @query,
        comment_counts: @comment_counts,
        filter_path: pull_request_commit_path(@pull_request, @commit.sha),
        layout: @layout,
        compact_line_height: @compact_line_height,
        show_file_tree: @show_file_tree %>
    <% end %>

    <section class="gh-diff-column">
      <article class="gh-card gh-commit-summary" data-role="commit-summary">
        <div class="gh-card-body">
          <h2><%= @commit.message %></h2>
          <% if @commit.body.present? %>
            <pre><%= @commit.body %></pre>
          <% end %>

          <div class="gh-commit-summary__footer">
            <span><%= @commit.author_name %> committed <%= time_ago_in_words(@commit.authored_at) %> ago</span>
            <code>commit <%= @commit.short_sha %></code>
          </div>

          <div class="gh-commit-summary__actions">
            <% if @previous_commit %>
              <%= link_to "Prev", pull_request_commit_path(@pull_request, @previous_commit.sha), class: "button button-secondary button-small" %>
            <% end %>
            <% if @next_commit %>
              <%= link_to "Next", pull_request_commit_path(@pull_request, @next_commit.sha), class: "button button-secondary button-small" %>
            <% end %>
            <%= link_to "Browse files", repository_pull_request_files_path(@local_repository, @pull_request), class: "button button-secondary button-small" %>
          </div>
        </div>
      </article>

      <% @files.each do |file| %>
        <%= render "pull_requests/diff_file",
          pull_request: @pull_request,
          file: file,
          comments_by_key: @comments_by_key,
          commit_sha: @commit.sha,
          redirect_path: pull_request_commit_path(@pull_request, @commit.sha),
          layout: @layout,
          compact_line_height: @compact_line_height,
          show_review_state: false %>
      <% end %>
    </section>
  </div>
</section>
