<div class="pf-page--conversation">
  <%= render "repository_header", local_repository: @local_repository %>

  <div class="pf-pulls-header">
    <h1>Pull requests</h1>
    <%= link_to "New pull request", repository_compare_path(@local_repository), class: "pf-button" %>
  </div>

  <div class="pf-pulls-filters">
    <%= link_to repository_pulls_path(@local_repository, status: "open"),
      class: "pf-pulls-filter #{"pf-pulls-filter--active" if @current_filter == :open}" do %>
      <%= octicon(:git_pull_request, size: 16) %> Open
    <% end %>
    <%= link_to repository_pulls_path(@local_repository, status: "closed"),
      class: "pf-pulls-filter #{"pf-pulls-filter--active" if @current_filter == :closed}" do %>
      <%= octicon(:check, size: 16) %> Closed
    <% end %>
  </div>

  <% if @pull_requests.any? %>
    <ul class="pf-pull-list">
      <% @pull_requests.each do |pull_request| %>
        <li class="pf-pull-list__item">
          <div class="pf-pull-list__info">
            <%= link_to repository_pull_path(@local_repository, pull_request), class: "pf-pull-list__title" do %>
              <%= octicon(:git_pull_request, size: 16) %>
              <strong><%= pull_request.title %></strong>
            <% end %>
            <span class="pf-pull-list__meta">
              #<%= pull_request.id %> opened <%= time_ago_in_words(pull_request.created_at) %> ago
              &middot; <%= pull_request.base_branch %> &larr; <%= pull_request.source_branch %>
            </span>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="pf-repo-list__empty">
      <%= octicon(:git_pull_request, size: 24) %>
      <h2>No pull requests yet</h2>
      <p>Compare branches and open your first pull request.</p>
      <%= link_to "New pull request", repository_compare_path(@local_repository), class: "pf-button" %>
    </div>
  <% end %>
</div>
