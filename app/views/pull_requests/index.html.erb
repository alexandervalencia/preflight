<div class="pf-page--conversation">
  <%= render "repository_header", local_repository: @local_repository %>

  <% if params[:exported].present? %>
    <div class="pf-export-success">
      <svg class="pf-export-success__icon" viewBox="0 0 98 96" width="64" height="64" fill="currentColor">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"/>
      </svg>
      <h2 class="pf-export-success__title">Pull request created!</h2>
      <p class="pf-export-success__detail"><%= params[:pr_title] %></p>
      <a href="<%= params[:pr_url] %>" target="_blank" rel="noopener" class="pf-button pf-export-success__link">
        View on GitHub &rarr;
      </a>
    </div>
  <% end %>

  <div class="pf-pulls-header">
    <h1>Pull requests</h1>
    <%= link_to "New pull request", repository_compare_path(@local_repository), class: "pf-button" %>
  </div>

  <% if @pull_requests.any? %>
    <ul class="pf-pull-list">
      <% @pull_requests.each do |pull_request| %>
        <li class="pf-pull-list__item">
          <div class="pf-pull-list__info">
            <%= link_to repository_pull_path(@local_repository, pull_request), class: "pf-pull-list__title" do %>
              <%= octicon(:git_pull_request, size: 16) %>
              <strong><%= pull_request.title %></strong>
            <% end %>
            <span class="pf-pull-list__meta">
              #<%= pull_request.id %> opened <%= time_ago_in_words(pull_request.created_at) %> ago
              &middot; <%= pull_request.base_branch %> &larr; <%= pull_request.source_branch %>
            </span>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="pf-repo-list__empty">
      <%= octicon(:git_pull_request, size: 24) %>
      <h2>No pull requests yet</h2>
      <p>Compare branches and open your first pull request.</p>
      <%= link_to "New pull request", repository_compare_path(@local_repository), class: "pf-button" %>
    </div>
  <% end %>
</div>
