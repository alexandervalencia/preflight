<article class="changed-file" data-role="changed-file" data-path="<%= file.path %>">
  <% if local_assigns[:show_review_state] %>
    <% state = file_view_state(pull_request, viewed_file) %>
  <% end %>
  <% stats = diff_stats(file) %>

  <header id="<%= file_anchor_id(file.path) %>">
    <div class="gh-file-header">
      <strong><%= file.path %></strong>
      <span><%= file.status %></span>
    </div>

    <div class="gh-file-stats">
      <span class="gh-additions">+<%= stats[:additions] %></span>
      <span class="gh-deletions">-<%= stats[:deletions] %></span>
    </div>

    <% if local_assigns[:show_review_state] %>
      <div class="file-review-tools">
        <span class="view-state <%= state.css_class %>" data-role="view-state"><%= state.label %></span>

        <% if state.action_label %>
          <%= button_to state.action_label,
            pull_request_viewed_files_path(pull_request),
            params: { path: file.path, redirect_to: redirect_path },
            class: "button button-small button-secondary" %>
        <% end %>
      </div>
    <% end %>
  </header>

  <table class="diff-table gh-split-diff">
    <tbody>
      <% split_diff_rows(file, comments_by_key).each do |row| %>
        <% left = row.left %>
        <% right = row.right %>

        <tr class="gh-split-row">
          <td class="line-number <%= "line-number--#{left.kind}" unless left.kind == :empty %>"><%= left.number %></td>
          <td class="line-code line-code--<%= left.kind %>"><code><%= left.content %></code></td>
          <td class="line-number <%= "line-number--#{right.kind}" unless right.kind == :empty %>"><%= right.number %></td>
          <td class="line-code line-code--<%= right.kind %>"><code><%= right.content %></code></td>
          <td class="line-form">
            <% if row.comment_side && row.comment_line_number %>
              <details class="inline-comment-shell">
                <summary>Add comment</summary>
                <%= form_with url: pull_request_inline_comments_path(pull_request), class: "inline-comment-form" do %>
                  <%= hidden_field_tag "inline_comment[path]", file.path %>
                  <%= hidden_field_tag "inline_comment[side]", row.comment_side %>
                  <%= hidden_field_tag "inline_comment[line_number]", row.comment_line_number %>
                  <%= hidden_field_tag "inline_comment[commit_sha]", commit_sha %>
                  <%= hidden_field_tag :redirect_to, redirect_path %>
                  <%= text_area_tag "inline_comment[body]", nil, rows: 2, placeholder: "Add a comment" %>
                  <%= submit_tag "Comment", class: "button button-small" %>
                <% end %>
              </details>
            <% end %>
          </td>
        </tr>

        <% row.comments.each do |comment| %>
          <tr class="comment-row">
            <td></td>
            <td></td>
            <td></td>
            <td></td>
            <td>
              <div class="inline-comment" data-role="inline-comment"><%= comment.body %></div>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</article>
