<article class="changed-file" data-role="changed-file" data-path="<%= file.path %>">
  <% if local_assigns[:show_review_state] %>
    <% state = file_view_state(pull_request, viewed_file) %>
  <% end %>
  <% stats = diff_stats(file) %>

  <header id="<%= file_anchor_id(file.path) %>">
    <div class="gh-file-header">
      <strong><%= file.path %></strong>
      <span><%= file.status %></span>
    </div>

    <div class="gh-file-stats">
      <span class="gh-additions">+<%= stats[:additions] %></span>
      <span class="gh-deletions">-<%= stats[:deletions] %></span>
    </div>

    <% if local_assigns[:show_review_state] %>
      <div class="file-review-tools">
        <span class="view-state <%= state.css_class %>" data-role="view-state"><%= state.label %></span>

        <% if state.action_label %>
          <%= button_to state.action_label,
            pull_request_viewed_files_path(pull_request),
            params: { path: file.path, redirect_to: redirect_path },
            class: "button button-small button-secondary" %>
        <% end %>
      </div>
    <% end %>
  </header>

  <table class="diff-table gh-split-diff">
    <tbody>
      <% split_diff_rows(file, comments_by_key).each do |row| %>
        <% left = row.left %>
        <% right = row.right %>
        <% row_key = "#{file_anchor_id(file.path)}-#{row.comment_side || "none"}-#{row.comment_line_number || "none"}" %>

        <tr class="gh-split-row">
          <td class="line-number <%= "line-number--#{left.kind}" unless left.kind == :empty %>"><%= left.number %></td>
          <td class="line-code line-code--<%= left.kind %> <%= "line-code--commentable" if row.comment_side == "left" %>">
            <% if row.comment_side == "left" && row.comment_line_number %>
              <details class="gh-inline-comment">
                <summary class="gh-inline-comment__summary" data-role="comment-trigger" aria-label="Add comment on this line">
                  <span>+</span>
                </summary>
                <div class="gh-inline-comment__popover">
                  <%= render "pull_requests/inline_comment_form",
                    pull_request: pull_request,
                    file: file,
                    side: row.comment_side,
                    line_number: row.comment_line_number,
                    commit_sha: commit_sha,
                    redirect_path: redirect_path %>
                </div>
              </details>
            <% end %>
            <div class="line-code__content"><code><%= left.content %></code></div>
          </td>
          <td class="line-number <%= "line-number--#{right.kind}" unless right.kind == :empty %>"><%= right.number %></td>
          <td class="line-code line-code--<%= right.kind %> <%= "line-code--commentable" if row.comment_side == "right" %>">
            <% if row.comment_side == "right" && row.comment_line_number %>
              <details class="gh-inline-comment">
                <summary class="gh-inline-comment__summary" data-role="comment-trigger" aria-label="Add comment on this line">
                  <span>+</span>
                </summary>
                <div class="gh-inline-comment__popover">
                  <%= render "pull_requests/inline_comment_form",
                    pull_request: pull_request,
                    file: file,
                    side: row.comment_side,
                    line_number: row.comment_line_number,
                    commit_sha: commit_sha,
                    redirect_path: redirect_path %>
                </div>
              </details>
            <% end %>
            <div class="line-code__content"><code><%= right.content %></code></div>
          </td>
          <td class="line-menu">
            <% if row.comment_side && row.comment_line_number %>
              <details class="gh-inline-menu">
                <summary class="gh-inline-menu__summary" data-role="comment-menu" aria-label="Line actions">
                  <span>&#8942;</span>
                </summary>
                <div class="gh-inline-menu__popover" id="<%= row_key %>-menu">
                  <p class="gh-inline-menu__title">Add comment on line <%= row.comment_line_number %></p>
                  <%= render "pull_requests/inline_comment_form",
                    pull_request: pull_request,
                    file: file,
                    side: row.comment_side,
                    line_number: row.comment_line_number,
                    commit_sha: commit_sha,
                    redirect_path: redirect_path %>
                </div>
              </details>
            <% end %>
          </td>
        </tr>

        <% row.comments.each do |comment| %>
          <tr class="comment-row">
            <td></td>
            <td></td>
            <td></td>
            <td></td>
            <td>
              <div class="inline-comment" data-role="inline-comment"><%= comment.body %></div>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</article>
