<div class="pf-page--conversation">
  <%= render "repository_header", local_repository: @local_repository %>

  <div class="pf-pulls-header">
    <h1>Comparing changes</h1>
  </div>

  <%# Branch selector card %>
  <div class="pf-compare-selector">
    <%= form_with url: repository_compare_path(@local_repository), method: :get, class: "pf-compare-form" do |form| %>
      <%= octicon(:git_pull_request, size: 16) %>
      <label class="pf-compare-label" for="base_branch">base:</label>
      <%= form.select :base_branch,
        options_for_select(@branches.map(&:name), @pull_request.base_branch),
        {},
        class: "pf-compare-dropdown",
        onchange: "this.form.requestSubmit()" %>
      <span class="pf-compare-arrow">&larr;</span>
      <label class="pf-compare-label" for="source_branch">compare:</label>
      <%= form.select :source_branch,
        options_for_select(@branches.map(&:name), @pull_request.source_branch),
        {},
        class: "pf-compare-dropdown",
        onchange: "this.form.requestSubmit()" %>
    <% end %>

    <%# Action banner %>
    <% if @pull_request.base_branch == @pull_request.source_branch %>
      <div class="pf-compare-banner">
        <p>Choose different branches to compare.</p>
      </div>
    <% elsif @existing_pull_request %>
      <div class="pf-compare-banner pf-compare-banner--existing" data-role="existing-pr-preview">
        <div>
          <strong><%= @existing_pull_request.title %></strong> #<%= @existing_pull_request.id %>
        </div>
        <%= link_to repository_pull_path(@local_repository, @existing_pull_request), class: "pf-button" do %>
          <%= octicon(:git_pull_request, size: 16) %> View pull request
        <% end %>
      </div>
    <% else %>
      <div class="pf-compare-banner">
        <p>These branches can be compared.</p>
        <button type="button" class="pf-button" id="pf-create-btn" onclick="document.getElementById('pf-create-form').hidden = false; this.hidden = true;">
          Create pull request
        </button>
      </div>
    <% end %>
  </div>

  <%# Create PR form (hidden until button clicked) %>
  <% unless @existing_pull_request || @pull_request.base_branch == @pull_request.source_branch %>
    <section class="pf-panel" id="pf-create-form" hidden>
      <%= form_with model: @pull_request, url: repository_pulls_path(@local_repository) do |form| %>
        <%= form.hidden_field :base_branch %>
        <%= form.hidden_field :source_branch %>

        <div class="pf-field">
          <%= form.label :title, "Title" %>
          <%= form.text_field :title, value: @pull_request.source_branch.titleize, class: "pf-create-title" %>
        </div>

        <div class="pf-field">
          <%= form.label :description, "Description" %>
          <%= form.text_area :description, rows: 5 %>
        </div>

        <% if @pull_request.errors.any? %>
          <div class="pf-errors">
            <%= @pull_request.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <%= form.submit "Create pull request", class: "pf-button" %>
      <% end %>
    </section>
  <% end %>

  <%# Comparison details (only when branches differ) %>
  <% if @comparison %>
    <%# Summary bar %>
    <% contributors = @commits.map(&:author_name).uniq %>
    <div class="pf-stats-bar pf-stats-bar--standalone">
      <span class="pf-stats-bar__item"><%= octicon(:git_commit, size: 16) %> <strong><%= @commits.length %></strong> <%= "commit".pluralize(@commits.length) %></span>
      <span class="pf-stats-bar__item"><%= octicon(:file, size: 16) %> <strong><%= @files.length %></strong> <%= "file".pluralize(@files.length) %> changed</span>
      <span class="pf-stats-bar__item"><%= octicon(:people, size: 16) %> <strong><%= contributors.count %></strong> <%= "contributor".pluralize(contributors.count) %></span>
    </div>

    <%# Commit list grouped by date with timeline %>
    <div class="pf-compare-timeline">
      <% @grouped_commits.each do |date, commits| %>
        <div class="pf-compare-timeline__group">
          <div class="pf-compare-timeline__header">
            <span class="pf-compare-timeline__badge"><%= octicon(:git_commit, size: 16) %></span>
            <span>Commits on <%= date.strftime("%b %-d, %Y") %></span>
          </div>

          <div class="pf-commit-group__list">
            <% commits.each do |commit| %>
              <article class="pf-commit-list-item">
                <div class="pf-commit-list-item__body">
                  <strong><%= format_commit_message(commit.message) %></strong>
                  <p>
                    <span class="pf-commit-list__avatar"><%= author_initials(commit.author_name) %></span>
                    <strong class="pf-commit-author-name"><%= commit.author_name %></strong> committed <%= time_ago_in_words(commit.authored_at) %> ago
                  </p>
                </div>

                <div class="pf-commit-list-item__meta">
                  <div class="pf-sha-pill">
                    <button type="button" class="pf-sha-pill__copy" data-action="copy-sha" data-sha="<%= commit.sha %>" title="Copy full SHA">
                      <%= octicon(:copy, size: 16) %>
                    </button>
                    <code class="pf-sha-pill__link"><%= commit.short_sha.first(7) %></code>
                  </div>
                </div>
              </article>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# File diffs %>
    <% total_adds = @files.sum { |f| diff_stats(f)[:additions] } %>
    <% total_dels = @files.sum { |f| diff_stats(f)[:deletions] } %>
    <section class="pf-compare-diffs">
      <div class="pf-diff-summary-bar">
        <div class="pf-diff-summary-bar__text">
          <%= octicon(:file, size: 16) %>
          Showing <strong><%= pluralize(@files.length, "changed file") %></strong> with <strong><%= pluralize(total_adds, "addition") %></strong> and <strong><%= pluralize(total_dels, "deletion") %></strong>.
        </div>
        <div class="pf-diff-view-toggle">
          <a href="?<%= request.query_parameters.merge(layout: "split").to_query %>" class="pf-diff-view-toggle__btn <%= "pf-diff-view-toggle__btn--active" unless diff_preference(:layout) == "unified" %>">Split</a>
          <a href="?<%= request.query_parameters.merge(layout: "unified").to_query %>" class="pf-diff-view-toggle__btn <%= "pf-diff-view-toggle__btn--active" if diff_preference(:layout) == "unified" %>">Unified</a>
        </div>
      </div>

      <% compare_layout = diff_preference(:layout) == "unified" ? :unified : :split %>
      <% @files.each do |file| %>
        <%= render "pull_requests/diff_file", file: file, layout: compare_layout, compact_line_height: true %>
      <% end %>
    </section>
  <% end %>
</div>
