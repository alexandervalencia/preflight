<% summary = pr_status_summary(comparison) %>
<% conversation_count = pull_request.inline_comments.count %>
<% commits_count = comparison.commits.count %>
<% changed_files_count = comparison.files.count %>
<% author_name = pull_request_author_name(comparison) %>

<header class="pf-pr-header">
  <p class="pf-breadcrumb">
    <%= link_to local_repository.name, repository_pull_requests_path(local_repository) %>
    <span>/</span>
    <span>pull request</span>
  </p>

  <div class="pf-pr-title-row">
    <div class="pf-pr-title-main">
      <div class="pf-pr-title-stack">
        <h1 class="pf-pr-title"><%= pull_request.title %></h1>
        <span class="pf-pr-number">#<%= pull_request.id %></span>
      </div>

      <% if active_tab == :conversation %>
        <details class="pf-title-editor">
          <summary aria-label="Edit title" class="pf-title-editor__summary">
            <span class="pf-title-editor__icon">&#9998;</span>
          </summary>

          <div class="pf-title-editor__popover">
            <%= form_with model: pull_request,
              url: repository_pull_request_path(local_repository, pull_request),
              class: "pf-title-editor__form" do |form| %>
              <%= form.label :title, "Edit title", class: "sr-only" %>
              <%= form.text_field :title, value: pull_request.title, class: "pf-title-editor__input" %>
              <%= form.hidden_field :base_branch, value: pull_request.base_branch %>
              <%= form.hidden_field :description, value: pull_request.description %>
              <div class="pf-title-editor__actions">
                <%= form.submit "Save", class: "button button-small" %>
              </div>
            <% end %>
          </div>
        </details>
      <% end %>
    </div>
  </div>

  <div class="pf-pr-meta">
    <span class="pf-state-badge"><%= octicon(:git_pull_request, size: 16) %> Open</span>
    <span class="pf-pr-meta__text">
      <strong><%= author_name %></strong> wants to merge
      <strong><%= pluralize(commits_count, "commit") %></strong>
      into
      <span class="pf-inline-branch" data-role="branch-pill"><%= pull_request.base_branch %></span>
      from
      <span class="pf-inline-branch" data-role="branch-pill"><%= pull_request.source_branch %></span>
    </span>
  </div>

  <nav class="pf-tabs">
    <%= link_to repository_pull_request_path(local_repository, pull_request),
      class: ["pf-tab", ("pf-tab--active" if active_tab == :conversation)] do %>
      <%= octicon(:comment, size: 16) %>
      <span>Conversation</span>
      <span class="pf-tab-count"><%= conversation_count %></span>
    <% end %>
    <%= link_to pull_request_commits_path(pull_request),
      class: ["pf-tab", ("pf-tab--active" if active_tab == :commits)] do %>
      <%= octicon(:git_commit, size: 16) %>
      <span>Commits</span>
      <span class="pf-tab-count"><%= commits_count %></span>
    <% end %>
    <%= link_to repository_pull_request_files_path(local_repository, pull_request),
      class: ["pf-tab", ("pf-tab--active" if active_tab == :files)] do %>
      <%= octicon(:file, size: 16) %>
      <span>Files changed</span>
      <span class="pf-tab-count"><%= changed_files_count %></span>
    <% end %>

    <div class="pf-tab-summary" data-role="pr-summary">
      <span class="pf-additions">+<%= summary[:additions] %></span>
      <span class="pf-deletions">-<%= summary[:deletions] %></span>
      <%= diffstat_blocks(summary[:additions], summary[:deletions]) %>
    </div>
  </nav>
</header>
