<section class="pf-page pf-page--conversation">
  <%= render "repository_header", local_repository: @local_repository %>

  <%= render "pull_request_header",
    local_repository: @local_repository,
    pull_request: @pull_request,
    comparison: @comparison,
    active_tab: :conversation %>

  <% author_name = pull_request_author_name(@comparison) %>

  <section class="pf-main-column pf-main-column--solo pf-conversation-page">
    <div class="pf-conversation-shell">
      <ol class="pf-timeline" data-role="conversation-timeline">
        <li class="pf-timeline-item pf-timeline-item--comment">
          <div class="pf-timeline-badge" aria-hidden="true"><%= author_initials(author_name) %></div>
          <article class="pf-card pf-comment-card" data-role="conversation-card"
                   data-controller="inline-edit">
            <header class="pf-card-header pf-comment-card__header">
              <div class="pf-comment-card__meta">
                <strong><%= author_name %></strong>
                <span>commented on <%= pull_request_timestamp(@pull_request.created_at) %></span>
              </div>
              <button type="button" class="pf-button pf-button--secondary pf-button--small"
                      data-inline-edit-target="editButton"
                      data-action="inline-edit#edit">Edit</button>
            </header>

            <div class="pf-card-body markdown-body pf-markdown-body"
                 data-inline-edit-target="display"
                 data-controller="task-list"
                 data-task-list-url-value="<%= repository_pull_path(@local_repository, @pull_request) %>"
                 data-task-list-base-branch-value="<%= @pull_request.base_branch %>"
                 data-task-list-description-value="<%= ERB::Util.html_escape(@pull_request.description) %>">
              <%= render_pull_request_markdown(@pull_request.description.presence || "No description provided yet.", interactive_tasks: true) %>
            </div>

            <div class="pf-card-body pf-description-edit" data-inline-edit-target="form" hidden>
              <%= form_with model: @pull_request, url: repository_pull_path(@local_repository, @pull_request), method: :patch do |form| %>
                <%= form.hidden_field :base_branch, value: @pull_request.base_branch %>
                <div data-controller="image-upload markdown-preview"
                     data-image-upload-url="<%= repository_pull_uploads_path(@local_repository, @pull_request) %>"
                     data-markdown-preview-url-value="<%= repository_pull_preview_path(@local_repository, @pull_request) %>">
                  <div class="pf-editor-tabs">
                    <button type="button" class="pf-editor-tab pf-editor-tab--active"
                            data-markdown-preview-target="writeTab"
                            data-action="markdown-preview#write">Write</button>
                    <button type="button" class="pf-editor-tab"
                            data-markdown-preview-target="previewTab"
                            data-action="markdown-preview#preview">Preview</button>
                  </div>
                  <div data-markdown-preview-target="writePanel">
                    <%= form.text_area :description, rows: 16,
                      class: "pf-description-edit__textarea",
                      data: { image_upload_target: "textarea", markdown_preview_target: "textarea" } %>
                    <div class="pf-dropzone"
                         data-image-upload-target="dropzone"
                         data-action="dragover->image-upload#dragover dragleave->image-upload#dragleave drop->image-upload#drop">
                      <button type="button" class="pf-button pf-button--secondary pf-button--small"
                              data-action="image-upload#selectFile">Attach an image</button>
                      <span class="pf-dropzone__hint">or drag and drop, or paste</span>
                      <span class="pf-dropzone__note">Images are stored locally. On export to GitHub, they'll become placeholders for you to re-upload.</span>
                      <input type="file" accept="image/png,image/jpeg,image/gif,image/webp" hidden
                             data-image-upload-target="fileInput"
                             data-action="image-upload#fileSelected">
                    </div>
                  </div>
                  <div data-markdown-preview-target="previewPanel" class="pf-preview-panel markdown-body pf-markdown-body" hidden></div>
                </div>
                <div class="pf-description-edit__actions">
                  <button type="button" class="pf-button pf-button--secondary pf-button--small" data-action="inline-edit#cancel">Cancel</button>
                  <%= form.submit "Update comment", class: "pf-button pf-button--small" %>
                </div>
              <% end %>
            </div>
          </article>
        </li>

        <% if @comparison.commits.any? %>
          <% contributors = @comparison.commits.map(&:author_name).uniq %>
          <li class="pf-timeline-item pf-timeline-item--stats">
            <div class="pf-stats-bar">
              <span class="pf-stats-bar__item"><%= octicon(:git_commit, size: 16) %> <strong><%= @comparison.commits.count %></strong> <%= "commit".pluralize(@comparison.commits.count) %></span>
              <span class="pf-stats-bar__item"><%= octicon(:file, size: 16) %> <strong><%= @comparison.files.count %></strong> <%= "file".pluralize(@comparison.files.count) %> changed</span>
              <span class="pf-stats-bar__item"><%= octicon(:people, size: 16) %> <strong><%= contributors.count %></strong> <%= "contributor".pluralize(contributors.count) %></span>
            </div>
          </li>

          <% @comparison.commits.group_by { |c| c.authored_at.to_date }.each do |date, commits| %>
            <li class="pf-timeline-item pf-timeline-item--commits">
              <div class="pf-timeline-badge pf-timeline-badge--commit" aria-hidden="true"><%= octicon(:git_commit, size: 16) %></div>
              <section class="pf-timeline-commits">
                <header class="pf-timeline-commits__header">Commits on <%= date.strftime("%b %-d, %Y") %></header>

                <div class="pf-commit-list">
                  <% commits.each do |commit| %>
                    <div class="pf-commit-list__item">
                      <div class="pf-commit-list__body">
                        <strong><%= link_to commit.message, repository_pull_commit_path(@local_repository, @pull_request, commit.sha), class: "pf-commit-list__message" %></strong>
                        <p class="pf-commit-list__author">
                          <span class="pf-commit-list__avatar"><%= author_initials(commit.author_name) %></span>
                          <strong><%= commit.author_name %></strong> committed on <%= commit.authored_at.strftime("%b %-d, %Y") %>
                        </p>
                      </div>
                      <div class="pf-sha-pill" data-controller="clipboard" data-clipboard-text-value="<%= commit.sha %>">
                        <button type="button" class="pf-sha-pill__copy" data-action="clipboard#copy" title="Copy full SHA">
                          <%= octicon(:copy, size: 16) %>
                        </button>
                        <%= link_to commit.short_sha, repository_pull_commit_path(@local_repository, @pull_request, commit.sha), class: "pf-sha-pill__link" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </section>
            </li>
          <% end %>
        <% end %>

        <% if @can_export %>
          <li class="pf-timeline-item pf-timeline-item--merge" data-controller="modal">
            <div class="pf-timeline-badge pf-timeline-badge--merge" aria-hidden="true">&#10003;</div>
            <section class="pf-merge-box">
              <header class="pf-merge-box__header">
                <strong>Ready to export</strong>
              </header>
              <p class="pf-merge-box__body">Review the files changed and update the description, then export to GitHub.</p>
              <div class="pf-export-actions">
                <button type="button" class="pf-button" data-action="modal#open">Create PR on GitHub</button>
              </div>
            </section>

            <div class="pf-modal-overlay" data-modal-target="overlay" data-action="click->modal#closeOnBackdrop" hidden>
              <div class="pf-modal">
                <header class="pf-modal__header">
                  <strong>Export to GitHub</strong>
                </header>
                <%= form_with url: repository_pull_github_export_path(@local_repository, @pull_request), method: :post,
                              data: { controller: "export-form" } do |f| %>
                  <div class="pf-modal__body">
                    <p>This will push your branch and create a pull request on GitHub using your current title and description.</p>

                    <% if @remotes.length > 1 %>
                      <div class="pf-modal__field">
                        <label class="pf-modal__label">Push to remote</label>
                        <%= f.select :remote, @remotes.map { |r| ["#{r.name} (#{r.url})", r.name] },
                          { selected: "origin" },
                          class: "pf-modal__select" %>
                      </div>
                    <% else %>
                      <%= f.hidden_field :remote, value: @remotes.first&.name || "origin" %>
                    <% end %>

                    <label class="pf-toggle">
                      <input type="checkbox" checked data-action="export-form#toggleDraft">
                      <span class="pf-toggle__label">Create as draft</span>
                      <span class="pf-toggle__hint">Draft PRs don't request review or trigger most notifications.</span>
                    </label>
                    <%= f.hidden_field :draft, value: "1", data: { export_form_target: "draftField" } %>
                  </div>
                  <footer class="pf-modal__footer">
                    <button type="button" class="pf-button pf-button--secondary" data-action="modal#close">Cancel</button>
                    <%= f.submit "Create pull request", class: "pf-button" %>
                  </footer>
                <% end %>
              </div>
            </div>
          </li>
        <% else %>
          <li class="pf-timeline-item pf-timeline-item--merge">
            <div class="pf-timeline-badge pf-timeline-badge--merge" aria-hidden="true">&#10003;</div>
            <section class="pf-merge-box">
              <header class="pf-merge-box__header">
                <strong>No conflicts with base branch</strong>
              </header>
              <p class="pf-merge-box__body">
                <% unless @gh_available %>
                  Install the <a href="https://cli.github.com" target="_blank" rel="noopener">GitHub CLI</a> to export PRs to GitHub.
                <% else %>
                  Review the files changed and update the description before you push this branch upstream.
                <% end %>
              </p>
            </section>
          </li>
        <% end %>
      </ol>
    </div>
  </section>
</section>
