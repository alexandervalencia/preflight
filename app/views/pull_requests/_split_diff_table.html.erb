<table class="diff-table pf-split-diff <%= "pf-diff-table--compact" if compact_line_height %>" data-role="split-diff">
  <colgroup>
    <col class="pf-col-number">
    <col class="pf-col-code">
    <col class="pf-col-number">
    <col class="pf-col-code">
  </colgroup>
  <tbody>
    <% split_diff_rows(file).each do |row| %>
      <% if row.kind == :hunk %>
        <tr class="pf-hunk-row">
          <td class="line-number line-number--hunk">...</td>
          <td class="line-code line-code--hunk" colspan="2">
            <code><%= row.hunk %></code>
          </td>
          <td class="line-number line-number--hunk">...</td>
        </tr>
        <% next %>
      <% end %>

      <% left = row.left %>
      <% right = row.right %>

      <tr class="pf-split-row">
        <td class="line-number <%= "line-number--#{left.kind}" unless left.kind == :empty %>"><%= left.number %></td>
        <td class="line-code line-code--<%= left.kind %>">
          <div class="line-code__content">
            <code><%= highlighted_diff_line(file.path, left.content, highlights: left.highlights) %></code>
          </div>
        </td>
        <td class="line-number <%= "line-number--#{right.kind}" unless right.kind == :empty %>"><%= right.number %></td>
        <td class="line-code line-code--<%= right.kind %>">
          <div class="line-code__content">
            <code><%= highlighted_diff_line(file.path, right.content, highlights: right.highlights) %></code>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
