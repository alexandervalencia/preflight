<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Preflight" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Preflight">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "variables",
                           "base",
                           "app-chrome",
                           "layout",
                           "repository",
                           "pr-header",
                           "conversation",
                           "commits",
                           "review-toolbar",
                           "file-tree",
                           "file-header",
                           "diff-table",
                           "inline-comments" %>
  </head>

  <body>
    <header class="app-chrome">
      <div class="app-chrome__inner">
        <%= link_to root_path, class: "brand" do %>
          <span class="brand-mark">P</span>
          <span>Preflight</span>
        <% end %>

        <div class="app-chrome__search" aria-hidden="true">Type / to search repositories</div>

        <nav class="app-chrome__nav">
          <%= link_to "Repositories", root_path, class: "app-chrome__link" %>
          <span class="app-chrome__link app-chrome__link--muted">Local reviews only</span>
        </nav>
      </div>
    </header>

    <main class="app-main">
      <%= yield %>
    </main>

    <script>
      document.addEventListener("click", function(e) {
        var btn = e.target.closest("[data-action='toggle-tree']");
        if (!btn) return;

        var layout = document.querySelector(".pf-review-layout");
        if (!layout) return;

        var hidden = layout.classList.toggle("pf-review-layout--tree-hidden");

        btn.querySelector("[data-tree-icon='collapse']").hidden = hidden;
        btn.querySelector("[data-tree-icon='expand']").hidden = !hidden;
        btn.setAttribute("aria-label", hidden ? "Show file tree" : "Hide file tree");

        var url = new URL(window.location);
        url.searchParams.set("tree", hidden ? "0" : "1");
        history.replaceState(null, "", url);
      });
    </script>
  </body>
</html>
