<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Preflight" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Preflight">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "variables",
                           "base",
                           "app-header",
                           "layout",
                           "repository",
                           "compare",
                           "pr-header",
                           "conversation",
                           "commits",
                           "review-toolbar",
                           "file-tree",
                           "file-header",
                           "diff-table" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="app-header">
      <div class="app-header__inner">
        <%= link_to root_path, class: "pf-brand" do %>
          <span class="pf-brand-mark">P</span>
          <span>Preflight</span>
        <% end %>
        <%= yield :nav_context %>
      </div>
    </header>

    <main class="app-main">
      <% if flash[:notice] %>
        <div class="pf-flash pf-flash--notice"><%= flash[:notice].html_safe %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="pf-flash pf-flash--alert"><%= flash[:alert] %></div>
      <% end %>
      <%= yield %>
    </main>

    <script>
      (function() {
        function setCookie(name, value) {
          document.cookie = name + "=" + value + ";path=/;max-age=31536000;SameSite=Lax";
        }

        // Save any explicit query params to cookies for future requests
        var params = new URLSearchParams(window.location.search);
        ["layout", "compact", "tree"].forEach(function(key) {
          if (params.has(key)) setCookie("pf_" + key, params.get(key));
        });

        // Tree toggle
        document.addEventListener("click", function(e) {
          var btn = e.target.closest("[data-action='toggle-tree']");
          if (!btn) return;

          var layout = document.querySelector(".pf-review-layout");
          if (!layout) return;

          var hidden = layout.classList.toggle("pf-review-layout--tree-hidden");

          btn.querySelector("[data-tree-icon='collapse']").hidden = hidden;
          btn.querySelector("[data-tree-icon='expand']").hidden = !hidden;
          btn.setAttribute("aria-label", hidden ? "Show file tree" : "Hide file tree");

          setCookie("pf_tree", hidden ? "0" : "1");
          var url = new URL(window.location);
          url.searchParams.set("tree", hidden ? "0" : "1");
          history.replaceState(null, "", url);
        });
        // Inline title editing
        document.addEventListener("click", function(e) {
          var editBtn = e.target.closest("[data-action='edit-title']");
          if (editBtn) {
            var row = editBtn.closest(".pf-pr-title-row");
            row.querySelector("[data-role='title-display']").hidden = true;
            var form = row.querySelector("[data-role='title-form']");
            form.hidden = false;
            form.querySelector(".pf-title-edit__input").focus();
            form.querySelector(".pf-title-edit__input").select();
            return;
          }

          var cancelBtn = e.target.closest("[data-action='cancel-title']");
          if (cancelBtn) {
            var row = cancelBtn.closest(".pf-pr-title-row");
            row.querySelector("[data-role='title-display']").hidden = false;
            row.querySelector("[data-role='title-form']").hidden = true;
            return;
          }

          // Inline description editing
          var editDescBtn = e.target.closest("[data-action='edit-description']");
          if (editDescBtn) {
            var card = editDescBtn.closest(".pf-comment-card");
            card.querySelector("[data-role='description-display']").hidden = true;
            var form = card.querySelector("[data-role='description-form']");
            form.hidden = false;
            editDescBtn.hidden = true;
            form.querySelector("textarea").focus();
            return;
          }

          var cancelDescBtn = e.target.closest("[data-action='cancel-description']");
          if (cancelDescBtn) {
            var card = cancelDescBtn.closest(".pf-comment-card");
            card.querySelector("[data-role='description-display']").hidden = false;
            card.querySelector("[data-role='description-form']").hidden = true;
            card.querySelector("[data-action='edit-description']").hidden = false;
            return;
          }

          // Copy SHA to clipboard
          var copyBtn = e.target.closest("[data-action='copy-sha']");
          if (copyBtn) {
            var sha = copyBtn.getAttribute("data-sha");
            navigator.clipboard.writeText(sha).then(function() {
              var icon = copyBtn.querySelector(".octicon");
              if (icon) {
                var original = icon.innerHTML;
                icon.innerHTML = '<path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z"></path>';
                setTimeout(function() { icon.innerHTML = original; }, 1500);
              }
            });
            return;
          }

          // Write/Preview tabs
          var writeTab = e.target.closest("[data-action='show-write-tab']");
          if (writeTab) {
            var container = writeTab.closest(".pf-description-edit");
            container.querySelector("[data-role='write-panel']").hidden = false;
            container.querySelector("[data-role='preview-panel']").hidden = true;
            writeTab.classList.add("pf-editor-tab--active");
            writeTab.nextElementSibling.classList.remove("pf-editor-tab--active");
            return;
          }

          var previewTab = e.target.closest("[data-action='show-preview-tab']");
          if (previewTab) {
            var container = previewTab.closest(".pf-description-edit");
            var textarea = container.querySelector("textarea");
            var previewPanel = container.querySelector("[data-role='preview-panel']");
            var writePanel = container.querySelector("[data-role='write-panel']");
            var previewUrl = container.querySelector("[data-action='show-preview-tab']")
              .closest(".pf-description-edit")
              .querySelector("form").action.replace(/\?.*/, "") + "/preview";

            previewPanel.innerHTML = "<p style='color: var(--pf-text-muted)'>Loading preview...</p>";
            writePanel.hidden = true;
            previewPanel.hidden = false;
            previewTab.classList.add("pf-editor-tab--active");
            previewTab.previousElementSibling.classList.remove("pf-editor-tab--active");

            fetch(previewUrl, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "X-CSRF-Token": document.querySelector("[name='csrf-token']").content
              },
              body: JSON.stringify({ text: textarea.value })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) { previewPanel.innerHTML = data.html || "<p style='color: var(--pf-text-muted)'>Nothing to preview.</p>"; })
            .catch(function() { previewPanel.innerHTML = "<p style='color: var(--pf-danger-text)'>Preview failed.</p>"; });
            return;
          }

          // Export modal
          var showModalBtn = e.target.closest("[data-action='show-export-modal']");
          if (showModalBtn) {
            var modal = document.querySelector("[data-role='export-modal']");
            if (modal) modal.hidden = false;
            return;
          }

          var closeModalBtn = e.target.closest("[data-action='close-export-modal']");
          if (closeModalBtn) {
            var modal = document.querySelector("[data-role='export-modal']");
            if (modal) modal.hidden = true;
            return;
          }

          // Close modal on overlay click
          if (e.target.matches("[data-role='export-modal']")) {
            e.target.hidden = true;
            return;
          }
        });

        // Draft toggle syncs checkbox to hidden field
        document.addEventListener("change", function(e) {
          var toggle = e.target.closest("[data-role='draft-toggle']");
          if (toggle) {
            var field = document.querySelector("[data-role='draft-field']");
            if (field) field.value = toggle.checked ? "1" : "0";
          }

          // Task list checkbox toggle
          var checkbox = e.target.closest(".pf-task-checkbox");
          if (checkbox) {
            var container = checkbox.closest("[data-role='description-display']");
            if (!container) return;

            var url = container.getAttribute("data-task-update-url");
            var description = container.getAttribute("data-description");
            var baseBranch = container.getAttribute("data-base-branch");
            var taskIndex = parseInt(checkbox.getAttribute("data-task-index"), 10);

            // Find the nth task in the markdown and toggle it
            var count = -1;
            var updated = description.replace(/- \[(x| )\]/gi, function(match, state) {
              count++;
              if (count === taskIndex) {
                return state.trim() ? "- [ ]" : "- [x]";
              }
              return match;
            });

            // Update the stored description
            container.setAttribute("data-description", updated);

            // Also update the textarea if the edit form is open
            var textarea = document.querySelector("[data-role='description-form'] textarea");
            if (textarea) textarea.value = updated;

            // PATCH the description
            fetch(url, {
              method: "PATCH",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
                "X-CSRF-Token": document.querySelector("[name='csrf-token']").content
              },
              body: "pull_request[description]=" + encodeURIComponent(updated) +
                    "&pull_request[base_branch]=" + encodeURIComponent(baseBranch)
            });
          }
        });
      })();
    </script>
  </body>
</html>
