<section class="page">
  <header class="page-header">
    <p class="eyebrow">Preflight</p>
    <h1>Browse local folders</h1>
    <p>Pick a git repository without typing a full filesystem path.</p>
  </header>

  <section class="panel">
    <div class="panel-header">
      <h2><%= @directory %></h2>
      <div class="directory-actions">
        <% if @parent_directory %>
          <%= link_to "Up one level", browse_path(directory: @parent_directory.to_s), class: "button button-secondary" %>
        <% end %>
        <%= link_to "Back to repositories", root_path, class: "button button-secondary" %>
      </div>
    </div>

    <div class="browse-list">
      <% @entries.each do |entry| %>
        <article class="browse-entry">
          <div>
            <strong><%= entry.name %></strong>
            <p><%= entry.path %></p>
          </div>

          <div class="directory-actions">
            <% if entry.git_repository %>
              <%= form_with model: LocalRepository.new, url: repositories_path do |form| %>
                <%= form.hidden_field :path, value: entry.path %>
                <%= form.hidden_field :name, value: entry.name %>
                <%= button_tag "Add #{entry.name}", type: "submit", class: "button" %>
              <% end %>
            <% else %>
              <%= link_to "Open folder", browse_path(directory: entry.path), class: "button button-secondary" %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  </section>
</section>
